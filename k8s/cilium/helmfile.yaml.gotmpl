# helmDefaults:
#   atomic: true
#   cleanupOnFail: true
#   wait: true
#   timeout: 600
#   recreatePods: false
#   force: false
repositories:
  - name: cilium
    # url: https://helm.cilium.io
    url: quay.io/cilium/charts
    oci: true
---
releases:
  - name: cilium
    namespace: kube-system
    chart: cilium/cilium
    version: 1.19.3
    values:
      - ./cilium/values.yaml.gotmpl
