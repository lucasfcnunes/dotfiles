resources:
  - apiVersion: cert-manager.io/v1
    kind: Certificate
    metadata:
      name: ca
    spec:
      isCA: true
      duration: 87600h # 10 years
      privateKey:
        algorithm: ECDSA
        size: 256
      secretName: ca
      commonName: lucasfcnunes-ca
      issuerRef:
        name: self-signed
        kind: ClusterIssuer
